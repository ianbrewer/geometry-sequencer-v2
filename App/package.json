{
  "name": "sacred-geometry-sequencer-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite --port 3008",
    "build": "npx tsc -b && npx vite build",
    "lint": "eslint .",
    "preview": "npx vite preview",
    "build:player": "npx vite build --config vite.player.config.ts",
    "build:pixi": "npx vite build --config vite.pixi.config.ts",
    "build:astro": "npx vite build --config vite.astro.config.ts",
    "build:amino": "npx vite build --config vite.amino.config.ts",
    "build:bundles": "npm run build:pixi && npm run build:astro && npm run build:amino && npm run build:player",
    "scene:list": "tsx scripts/scene/list.ts",
    "scene:pull": "tsx scripts/scene/pull.ts",
    "scene:push": "tsx scripts/scene/push.ts",
    "scene:new": "tsx scripts/scene/new.ts",
    "scene:assets": "tsx scripts/scene/assets.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.1",
    "@supabase/supabase-js": "^2.93.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@types/jszip": "^3.4.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.15.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.1",
    "zustand": "^5.0.9"
  }
}
