{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: app",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/App" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "dev",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: taskboard",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/scripts/taskboard" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "dev",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: all",
      "dependsOn": ["dev: app", "dev: taskboard"],
      "dependsOrder": "parallel",
      "runOptions": { "runOn": "folderOpen" },
      "problemMatcher": []
    }
  ]
}
